{
  "name": "sullytear",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/generate-build-info.js && node scripts/compile-models.mjs && node scripts/validate-gltf.mjs",
    "predev": "node scripts/generate-build-info.js",
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:models": "node scripts/compile-models.mjs",
    "validate:models": "node scripts/validate-gltf.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "sim": "node --import tsx scripts/sim/runner.mjs",
    "typecheck": "node scripts/generate-build-info.js && tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.115.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.19.1",
    "framer-motion": "^11.11.0",
    "postprocessing": "^6.39.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "esbuild": "^0.27.7",
    "smol-toml": "^1.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  }
}
